# Optional alternative:
# DATABASE_URL=postgres://postgres:postgres@localhost:5432/agri_assist?sslmode=disable
#
# If the backend runs inside WSL and localhost does not reach Docker Desktop,
# change DB_HOST to host.docker.internal.
PORT=8080
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=agri_assist
DB_SSLMODE=disable
DB_TIMEZONE=UTC
